{
  "name": "clippers-command-center",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "backfill": "node --env-file=.env.local node_modules/.bin/tsx scripts/backfill.ts",
    "compute-stats": "node --env-file=.env.local node_modules/.bin/tsx scripts/compute-stats.ts",
    "generate-insights": "node --env-file=.env.local node_modules/.bin/tsx scripts/generate-insights.ts",
    "sync-schedule": "node --env-file=.env.local node_modules/.bin/tsx scripts/sync-schedule.ts",
    "poll-live": "node --env-file=.env.local node_modules/.bin/tsx scripts/poll-live.ts",
    "finalize-games": "node --env-file=.env.local node_modules/.bin/tsx scripts/finalize-games.ts",
    "sync-odds": "node --env-file=.env.local node_modules/.bin/tsx scripts/sync-odds.ts",
    "db:schema": "node --env-file=.env.local -e \"const postgres=require('postgres');const fs=require('fs');const sql=postgres(process.env.DATABASE_URL,{ max: 1 });sql.unsafe(fs.readFileSync('docs/DB_SCHEMA.sql','utf8')).then(()=>{console.log('Schema applied');return sql.end()}).catch(e=>{console.error(e);process.exit(1)})\""
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "postgres": "^3.4.8",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.7.0",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.37",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
