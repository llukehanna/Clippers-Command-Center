# Neon PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# BALLDONTLIE API key (get from balldontlie.io)
BALLDONTLIE_API_KEY=your_api_key_here

# TheOdds API key (get from the-odds-api.com)
ODDS_API_KEY=your_odds_api_key_here

# Rate limit delay in milliseconds between BDL API requests.
# Free tier (5 req/min): use 12000. ALL-STAR tier (60 req/min): use 1000.
# Local BDL script rate-limit delay. Not used in production (Vercel Cron).
DELAY_MS=12000
